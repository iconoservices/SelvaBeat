# SELVABEAT PREMIUM - CONFIGURACIÓN DE FIREBASE
# Copia este archivo a .env y completa los valores.

VITE_FIREBASE_API_KEY=tu_api_key_aquí
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
VITE_FIREBASE_APP_ID=1:tu_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-tu_measurement_id

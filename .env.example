# 🌴 SelvaBeat Environment Variables
# Copy these values into Vercel Settings -> Environment Variables

# 🔐 Token Maestre para comunicación con el Worker
# En el internet usa un token seguro. En LocalDev usa: selva_master_key_2026_premium
VITE_AUTH_TOKEN=tu_llave_secreta_aqui

# 📡 URL de tu Cloudflare Worker Proxy
# Ejemplo: https://icono-proxy.tu-usuario.workers.dev
VITE_WORKER_URL=https://icono-proxy.jnmcsky.workers.dev
